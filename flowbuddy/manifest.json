{
  "manifest_version": 3,
  "name": "FlowBuddy",
  "version": "1.0.0",
  "description": "Teman kerja ultra-ringan — tugas cepat, catatan, chat, dan approval. Ekstensi modular berbasis peran.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["css/mascot.css"],
      "js": ["js/mascot-state.js", "js/sync.js", "mascot-content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://happily-flowbuddy.vercel.app/*", "*://localhost/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FlowBuddy — Aksi cepat"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "css/*",
        "js/*",
        "icons/*",
        "popup.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}